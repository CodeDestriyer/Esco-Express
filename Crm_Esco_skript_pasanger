/**
 * Отримує всіх пасажирів з аркуша
 */
function getAllPassengers_(sheetName) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(sheetName);
  if (!sheet) return { success: true, data: [] };

  var headerRow = SCRIPT_CONFIG.HEADER_ROW;
  var dataStartRow = SCRIPT_CONFIG.DATA_START_ROW;
  var lastRow = sheet.getLastRow();
  var lastCol = sheet.getLastColumn();

  if (lastRow < dataStartRow || lastCol === 0) return { success: true, data: [] };

  var headers = sheet.getRange(headerRow, 1, 1, lastCol).getValues()[0];
  var data = sheet.getRange(dataStartRow, 1, lastRow - dataStartRow + 1, lastCol).getValues();

  var records = [];
  for (var i = 0; i < data.length; i++) {
    if (!data[i][0] && !data[i][1]) continue;
    var obj = {};
    for (var j = 0; j < headers.length; j++) {
      obj[headers[j]] = data[i][j] !== undefined ? data[i][j] : "";
    }
    obj._rowNum = dataStartRow + i;
    records.push(obj);
  }
  return { success: true, data: records };
}

/**
 * Створює нового пасажира
 */
function createPassengerLocal_(data, sheetName) {
  sheetName = sheetName || SCRIPT_CONFIG.SHEET_UA_EU;
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(sheetName);

  var paxId = "PAX-" + Utilities.formatDate(new Date(), "UTC", "yyyyMMdd") + "-" + Math.random().toString(36).substr(2, 4).toUpperCase();
  var entry = {};
  var cols = SCRIPT_CONFIG.COLUMNS;
  for (var i = 0; i < cols.length; i++) {
    entry[cols[i]] = "";
  }

  entry["PAX_ID"] = paxId;
  entry["Ід_смарт/CRM"] = data.smartId || "";
  entry["Напрям"] = sheetName === SCRIPT_CONFIG.SHEET_UA_EU ? "УК → ЄВ" : "ЄВ → УК";
  entry["SOURCE_SHEET"] = sheetName;
  entry["Дата створення"] = new Date();
  entry["Піб"] = data.name || "";
  entry["Телефон пасажира"] = data.phone || "";
  entry["Телефон реєстратора"] = data.phoneReg || "";
  entry["Кількість місць"] = data.seats || 1;
  entry["Адреса прибуття"] = data.address || "";
  entry["Дата виїзду"] = data.departureDate || "";
  entry["Таймінг"] = data.timing || "";
  entry["Номер авто"] = data.vehicle || "";
  entry["Місце в авто"] = data.seat || "";
  entry["Ціна квитка"] = data.price || "";
  entry["Завдаток"] = data.deposit || "";
  entry["Статус оплати"] = data.payStatus || "Не оплачено";
  entry["Форма оплати"] = data.payForm || "";
  entry["Валюта"] = data.currency || "UAH";
  entry["Вага багажу"] = data.weight || "";
  entry["Ціна багажу"] = data.weightPrice || "";
  entry["Статус ліда"] = "Новий";
  entry["Статус CRM"] = "Активний";

  var values = cols.map(function(h) { return entry[h] !== undefined ? entry[h] : ""; });
  sheet.appendRow(values);

  return paxId;
}

/**
 * Оновлює одне поле пасажира за PAX_ID
 */
function updateFieldLocal_(sheetName, idColumn, recordId, field, value) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(sheetName);
  if (!sheet) throw new Error("Аркуш " + sheetName + " не знайдено");

  var headerRow = SCRIPT_CONFIG.HEADER_ROW;
  var dataStartRow = SCRIPT_CONFIG.DATA_START_ROW;
  var lastRow = sheet.getLastRow();
  var lastCol = sheet.getLastColumn();

  var headers = sheet.getRange(headerRow, 1, 1, lastCol).getValues()[0];
  var idCol = headers.indexOf(idColumn);
  var fieldCol = headers.indexOf(field);
  if (idCol === -1) throw new Error("Колонка " + idColumn + " не знайдена");
  if (fieldCol === -1) throw new Error("Колонка " + field + " не знайдена");

  if (lastRow < dataStartRow) throw new Error("Немає даних");

  var ids = sheet.getRange(dataStartRow, idCol + 1, lastRow - dataStartRow + 1, 1).getValues();
  for (var i = 0; i < ids.length; i++) {
    if (ids[i][0] == recordId) {
      sheet.getRange(dataStartRow + i, fieldCol + 1).setValue(value);
      return;
    }
  }
  throw new Error("Запис " + recordId + " не знайдено");
}

/**
 * Видаляє пасажирів по sheet + rowNum
 */
function deletePassengersLocal_(passengersList) {
  var grouped = {};
  for (var i = 0; i < passengersList.length; i++) {
    var p = passengersList[i];
    var sn = p.sheet;
    if (!grouped[sn]) grouped[sn] = [];
    grouped[sn].push(p.rowNum);
  }

  var ss = SpreadsheetApp.getActiveSpreadsheet();
  for (var sheetName in grouped) {
    var sheet = ss.getSheetByName(sheetName);
    if (!sheet) continue;
    var rows = grouped[sheetName].sort(function(a, b) { return b - a; });
    for (var j = 0; j < rows.length; j++) {
      sheet.deleteRow(rows[j]);
    }
  }
}

/**
 * Архівує пасажирів (позначає як Скасовано)
 */
function archivePassengersLocal_(payload) {
  var list = payload.passengers || [payload];
  var ss = SpreadsheetApp.getActiveSpreadsheet();

  for (var i = 0; i < list.length; i++) {
    var p = list[i];
    var sheet = ss.getSheetByName(p.sheet);
    if (!sheet || !p.rowNum) continue;

    var headerRow = SCRIPT_CONFIG.HEADER_ROW;
    var lastCol = sheet.getLastColumn();
    var headers = sheet.getRange(headerRow, 1, 1, lastCol).getValues()[0];
    var statusCol = headers.indexOf("Статус CRM");
    var archDateCol = headers.indexOf("DATE_ARCHIVE");
    var archByCol = headers.indexOf("ARCHIVED_BY");
    var archReasonCol = headers.indexOf("ARCHIVE_REASON");

    if (statusCol !== -1) sheet.getRange(p.rowNum, statusCol + 1).setValue("Скасовано");
    if (archDateCol !== -1) sheet.getRange(p.rowNum, archDateCol + 1).setValue(new Date());
    if (archByCol !== -1) sheet.getRange(p.rowNum, archByCol + 1).setValue(payload.user || "CRM");
    if (archReasonCol !== -1) sheet.getRange(p.rowNum, archReasonCol + 1).setValue(payload.reason || "");
  }
}

/**
 * Відновлює пасажирів (знімає Скасовано)
 */
function restorePassengersLocal_(payload) {
  var list = payload.passengers || [payload];
  var ss = SpreadsheetApp.getActiveSpreadsheet();

  for (var i = 0; i < list.length; i++) {
    var p = list[i];
    var sheet = ss.getSheetByName(p.sheet);
    if (!sheet || !p.rowNum) continue;

    var headerRow = SCRIPT_CONFIG.HEADER_ROW;
    var lastCol = sheet.getLastColumn();
    var headers = sheet.getRange(headerRow, 1, 1, lastCol).getValues()[0];
    var statusCol = headers.indexOf("Статус CRM");
    var archDateCol = headers.indexOf("DATE_ARCHIVE");
    var archByCol = headers.indexOf("ARCHIVED_BY");
    var archReasonCol = headers.indexOf("ARCHIVE_REASON");

    if (statusCol !== -1) sheet.getRange(p.rowNum, statusCol + 1).setValue("Активний");
    if (archDateCol !== -1) sheet.getRange(p.rowNum, archDateCol + 1).setValue("");
    if (archByCol !== -1) sheet.getRange(p.rowNum, archByCol + 1).setValue("");
    if (archReasonCol !== -1) sheet.getRange(p.rowNum, archReasonCol + 1).setValue("");
  }
}
