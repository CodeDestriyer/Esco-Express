/**
 * Розфарбовує статусні клітинки одного рядка
 */
function colorRowStatuses_(sheet, headers, row) {
  var statusCols = ["Статус ліда", "Статус CRM", "Статус оплати"];
  for (var i = 0; i < statusCols.length; i++) {
    var colIdx = headers.indexOf(statusCols[i]);
    if (colIdx === -1) continue;
    var cell = sheet.getRange(row, colIdx + 1);
    var value = cell.getValue();
    if (SCRIPT_CONFIG.COLORS[value]) {
      cell.setBackground(SCRIPT_CONFIG.COLORS[value]);
    }
  }
}


