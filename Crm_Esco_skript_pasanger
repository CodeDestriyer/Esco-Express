// ══════════════════════════════════════════════════════════════
// ТРИГЕР onEdit — Реакція на зміни в таблиці
// ══════════════════════════════════════════════════════════════

function onEdit(e) {
  var sheet = e.source.getActiveSheet();
  var sheetName = sheet.getName();

  // Працюємо тільки з аркушами пасажирів
  if (sheetName !== SCRIPT_CONFIG.SHEET_UA_EU &&
      sheetName !== SCRIPT_CONFIG.SHEET_EU_UA) return;

  var range = e.range;
  var row = range.getRow();
  var col = range.getColumn();

  // Ігноруємо зміни в заголовках (рядки 1-4)
  if (row < SCRIPT_CONFIG.DATA_START_ROW) return;

  // Отримуємо назву колонки
  var headers = getHeaders_(sheet);
  if (col > headers.length) return;
  var columnName = headers[col - 1];

  // Перевіряємо чи колонка заблокована
  if (SCRIPT_CONFIG.LOCKED_COLUMNS.indexOf(columnName) !== -1) {
    // Повертаємо старе значення
    range.setValue(e.oldValue || "");
    SpreadsheetApp.getUi().alert(
      "🔒 Колонка «" + columnName + "» захищена від редагування.\n" +
      "Ця колонка заповнюється автоматично системою."
    );
    return;
  }

  // Розфарбовуємо статусні колонки
  if (SCRIPT_CONFIG.COLORS[e.value]) {
    range.setBackground(SCRIPT_CONFIG.COLORS[e.value]);
  }

  // Оновлюємо в CRM через API (фоново)
  var paxId = getPaxIdForRow_(sheet, row);
  if (paxId && columnName) {
    syncFieldToCrm_(sheetName, paxId, columnName, e.value || "", getUserEmail_());
  }
}


// ══════════════════════════════════════════════════════════════
// ІНСТАЛЬОВАНИЙ ТРИГЕР onChange — для структурних змін
// ══════════════════════════════════════════════════════════════

/**
 * Встановлює installable тригер (викликати 1 раз вручну)
 */
function installTriggers() {
  // Видаляємо старі тригери цього проекту
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    ScriptApp.deleteTrigger(triggers[i]);
  }

  // Встановлюємо onEdit (installable — для доступу до API)
  ScriptApp.newTrigger("onEditInstallable")
    .forSpreadsheet(SpreadsheetApp.getActive())
    .onEdit()
    .create();
}

/**
 * Installable onEdit — має доступ до UrlFetchApp (може слати в CRM)
 */
function onEditInstallable(e) {
  var sheet = e.source.getActiveSheet();
  var sheetName = sheet.getName();

  if (sheetName !== SCRIPT_CONFIG.SHEET_UA_EU &&
      sheetName !== SCRIPT_CONFIG.SHEET_EU_UA) return;

  var row = e.range.getRow();
  var col = e.range.getColumn();

  if (row < SCRIPT_CONFIG.DATA_START_ROW) return;

  var headers = getHeaders_(sheet);
  if (col > headers.length) return;
  var columnName = headers[col - 1];

  // Пропускаємо заблоковані
  if (SCRIPT_CONFIG.LOCKED_COLUMNS.indexOf(columnName) !== -1) return;

  // Синхронізуємо зміну в CRM
  var paxId = getPaxIdForRow_(sheet, row);
  if (paxId && columnName) {
    try {
      sendToCrmApi_("updateField", {
        spreadsheetId: "PASSENGERS",
        sheet: sheetName,
        idColumn: "PAX_ID",
        recordId: paxId,
        field: columnName,
        value: e.value || "",
        updatedBy: getUserEmail_()
      });
    } catch (err) {
      Logger.log("CRM sync error: " + err.message);
    }
  }
}


// ══════════════════════════════════════════════════════════════
// ДОПОМІЖНІ ФУНКЦІЇ
// ══════════════════════════════════════════════════════════════

/**
 * Повертає заголовки колонок (рядок 3)
 */
function getHeaders_(sheet) {
  return sheet.getRange(SCRIPT_CONFIG.HEADER_ROW, 1, 1, sheet.getLastColumn()).getValues()[0];
}

/**
 * Отримує PAX_ID для конкретного рядка
 */
function getPaxIdForRow_(sheet, row) {
  var headers = getHeaders_(sheet);
  var paxIdCol = headers.indexOf("PAX_ID");
  if (paxIdCol === -1) return null;
  return sheet.getRange(row, paxIdCol + 1).getValue();
}

/**
 * Отримує email поточного користувача
 */
function getUserEmail_() {
  try {
    return Session.getActiveUser().getEmail() || "Таблиця";
  } catch (e) {
    return "Таблиця";
  }
}

/**
 * Знаходить індекс колонки за назвою
 */
function getColumnIndex_(headers, columnName) {
  return headers.indexOf(columnName);
}

/**
 * Конвертує рядок у об'єкт
 */
function rowToObject_(headers, rowData) {
  var obj = {};
  for (var i = 0; i < headers.length; i++) {
    obj[headers[i]] = rowData[i] !== undefined ? rowData[i] : "";
  }
  return obj;
}

/**
 * Конвертує об'єкт назад у масив
 */
function objectToRow_(headers, obj) {
  return headers.map(function(h) {
    return obj[h] !== undefined ? obj[h] : "";
  });
}

/**
 * Генерує PAX_ID
 */
function generatePaxId_() {
  var date = Utilities.formatDate(new Date(), "UTC", "yyyyMMdd");
  var random = Math.random().toString(36).substr(2, 4).toUpperCase();
  return "PAX-" + date + "-" + random;
}


// ══════════════════════════════════════════════════════════════
// API — ВИКЛИКИ ДО CRM BACKEND
// ══════════════════════════════════════════════════════════════

/**
 * Виконує дію напряму (замість HTTP запиту до зовнішнього бекенду)
 */
function sendToCrmApi_(action, data) {
  try {
    if (action === "createPassenger") {
      var id = createPassengerLocal_(data.data || data, data.sheet);
      return { success: true, id: id };
    }
    else if (action === "updateField") {
      updateFieldLocal_(data.sheet, data.idColumn || "PAX_ID", data.recordId, data.field, data.value);
      return { success: true };
    }
    else if (action === "archive") {
      archivePassengersLocal_({ passengers: [{ sheet: data.sheet, rowNum: data.rowNum }], user: data.archivedBy, reason: data.reason });
      return { success: true };
    }
    else {
      Logger.log("sendToCrmApi_: невідома дія — " + action);
      return { success: false, error: "Unknown action: " + action };
    }
  } catch (err) {
    Logger.log("sendToCrmApi_ error: " + err.message);
    return { success: false, error: err.message };
  }
}

/**
 * GET запит — тепер локально
 */
function getFromCrmApi_(action, params) {
  try {
    if (action === "getPassengers") {
      return getAllPassengers_(params.sheet || SCRIPT_CONFIG.SHEET_UA_EU);
    }
    return { success: false, error: "Unknown action: " + action };
  } catch (err) {
    return { success: false, error: err.message };
  }
}

/**
 * Синхронізує одне поле з CRM (викликається з onEdit)
 */
function syncFieldToCrm_(sheetName, paxId, field, value, updatedBy) {
  try {
    sendToCrmApi_("updateField", {
      spreadsheetId: "PASSENGERS",
      sheet: sheetName,
      idColumn: "PAX_ID",
      recordId: paxId,
      field: field,
      value: value,
      updatedBy: updatedBy
    });
  } catch (err) {
    Logger.log("Sync field error: " + err.message);
  }
}


