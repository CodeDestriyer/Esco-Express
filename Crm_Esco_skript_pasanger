function menuShowStats() {
  var sheet = SpreadsheetApp.getActiveSheet();
  var sheetName = sheet.getName();
  var headers = getHeaders_(sheet);
  var lastRow = sheet.getLastRow();
  var startRow = SCRIPT_CONFIG.DATA_START_ROW;

  if (lastRow < startRow) {
    SpreadsheetApp.getUi().alert("ℹ️ Немає даних");
    return;
  }

  var data = sheet.getRange(startRow, 1, lastRow - startRow + 1, headers.length).getValues();
  var leadStatusCol = headers.indexOf("Статус ліда");
  var crmStatusCol = headers.indexOf("Статус CRM");
  var payStatusCol = headers.indexOf("Статус оплати");
  var seatsCol = headers.indexOf("Кількість місць");
  var priceCol = headers.indexOf("Ціна квитка");

  var stats = {
    total: 0,
    leads: { "Новий": 0, "В обробці": 0, "Підтверджено": 0, "Скасовано": 0 },
    crm: { "Активний": 0, "Скасовано": 0, "Архів": 0 },
    pay: { "Оплачено": 0, "Частково": 0, "Не оплачено": 0 },
    totalSeats: 0,
    totalRevenue: 0,
  };

  for (var i = 0; i < data.length; i++) {
    if (!data[i][0] && !data[i][1]) continue;
    stats.total++;

    var leadStatus = data[i][leadStatusCol] || "Новий";
    var crmStatus = data[i][crmStatusCol] || "Активний";
    var payStatus = data[i][payStatusCol] || "Не оплачено";

    if (stats.leads[leadStatus] !== undefined) stats.leads[leadStatus]++;
    if (stats.crm[crmStatus] !== undefined) stats.crm[crmStatus]++;
    if (stats.pay[payStatus] !== undefined) stats.pay[payStatus]++;

    stats.totalSeats += Number(data[i][seatsCol]) || 0;
    stats.totalRevenue += parseFloat(String(data[i][priceCol] || "0").replace(/[^0-9.,]/g, "").replace(",", ".")) || 0;
  }

  var msg = "📊 СТАТИСТИКА — " + sheetName + "\n\n"
    + "Всього записів: " + stats.total + "\n"
    + "Всього місць: " + stats.totalSeats + "\n"
    + "Загальна сума: " + stats.totalRevenue.toFixed(0) + "\n\n"
    + "── Статус ліда ──\n"
    + "🟡 Новий: " + stats.leads["Новий"] + "\n"
    + "🔵 В обробці: " + stats.leads["В обробці"] + "\n"
    + "🟢 Підтверджено: " + stats.leads["Підтверджено"] + "\n"
    + "🔴 Скасовано: " + stats.leads["Скасовано"] + "\n\n"
    + "── Статус CRM ──\n"
    + "✅ Активний: " + stats.crm["Активний"] + "\n"
    + "❌ Скасовано: " + stats.crm["Скасовано"] + "\n"
    + "📦 Архів: " + (stats.crm["Архів"] || 0) + "\n\n"
    + "── Оплата ──\n"
    + "💰 Оплачено: " + stats.pay["Оплачено"] + "\n"
    + "⚠️ Частково: " + stats.pay["Частково"] + "\n"
    + "❗ Не оплачено: " + stats.pay["Не оплачено"];

  SpreadsheetApp.getUi().alert(msg);
}


