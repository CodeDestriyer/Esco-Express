function menuSyncToCrm() {
  var ui = SpreadsheetApp.getUi();
  var result = ui.alert(
    "🔄 Синхронізація",
    "Надіслати всіх активних пасажирів з поточного аркуша в CRM?\n\n" +
    "Це оновить дані в CRM відповідно до таблиці.",
    ui.ButtonSet.YES_NO
  );

  if (result !== ui.Button.YES) return;

  var sheet = SpreadsheetApp.getActiveSheet();
  var sheetName = sheet.getName();

  if (sheetName !== SCRIPT_CONFIG.SHEET_UA_EU &&
      sheetName !== SCRIPT_CONFIG.SHEET_EU_UA) {
    ui.alert("⚠️ Перейдіть на аркуш пасажирів");
    return;
  }

  syncSheetToCrm_(sheet, sheetName);
}

/**
 * Синхронізує весь аркуш з CRM
 */
function syncSheetToCrm_(sheet, sheetName) {
  var headers = getHeaders_(sheet);
  var lastRow = sheet.getLastRow();
  var startRow = SCRIPT_CONFIG.DATA_START_ROW;

  if (lastRow < startRow) {
    SpreadsheetApp.getUi().alert("ℹ️ Немає даних для синхронізації");
    return;
  }

  var data = sheet.getRange(startRow, 1, lastRow - startRow + 1, headers.length).getValues();
  var paxIdCol = headers.indexOf("PAX_ID");
  var crmStatusCol = headers.indexOf("Статус CRM");
  var synced = 0;
  var errors = 0;

  for (var i = 0; i < data.length; i++) {
    var row = rowToObject_(headers, data[i]);

    // Пропускаємо порожні рядки
    if (!row["PAX_ID"] && !row["Піб"]) continue;

    // Пропускаємо архівовані
    if (row["Статус CRM"] === "Архів" || row["Статус CRM"] === "Скасовано") continue;

    // Якщо немає PAX_ID — генеруємо і записуємо
    if (!row["PAX_ID"]) {
      var newId = generatePaxId_();
      sheet.getRange(startRow + i, paxIdCol + 1).setValue(newId);
      row["PAX_ID"] = newId;
    }

    // Оновлюємо всі editable поля в CRM
    for (var j = 0; j < SCRIPT_CONFIG.EDITABLE_COLUMNS.length; j++) {
      var field = SCRIPT_CONFIG.EDITABLE_COLUMNS[j];
      try {
        sendToCrmApi_("updateField", {
          spreadsheetId: "PASSENGERS",
          sheet: sheetName,
          idColumn: "PAX_ID",
          recordId: row["PAX_ID"],
          field: field,
          value: row[field] || "",
          updatedBy: getUserEmail_()
        });
      } catch (err) {
        errors++;
        Logger.log("Sync error row " + (startRow + i) + " field " + field + ": " + err.message);
      }
    }
    synced++;
  }

  SpreadsheetApp.getUi().alert(
    "✅ Синхронізація завершена\n\n" +
    "Синхронізовано: " + synced + " записів\n" +
    (errors > 0 ? "Помилок: " + errors : "Без помилок")
  );
}


