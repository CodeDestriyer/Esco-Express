/**
 * Генерує PAX_ID для всіх рядків де його немає
 */
function fillMissingPaxIds() {
  var sheet = SpreadsheetApp.getActiveSheet();
  var headers = getHeaders_(sheet);
  var paxIdCol = headers.indexOf("PAX_ID");
  if (paxIdCol === -1) return;

  var lastRow = sheet.getLastRow();
  var startRow = SCRIPT_CONFIG.DATA_START_ROW;
  var filled = 0;

  for (var row = startRow; row <= lastRow; row++) {
    var cell = sheet.getRange(row, paxIdCol + 1);
    if (!cell.getValue()) {
      // Перевіряємо чи рядок не порожній
      var nameCell = sheet.getRange(row, headers.indexOf("Піб") + 1);
      var phoneCell = sheet.getRange(row, headers.indexOf("Телефон пасажира") + 1);
      if (nameCell.getValue() || phoneCell.getValue()) {
        cell.setValue(generatePaxId_());
        filled++;
      }
    }
  }

  if (filled > 0) {
    SpreadsheetApp.getUi().alert("✅ Згенеровано PAX_ID для " + filled + " записів");
  } else {
    SpreadsheetApp.getUi().alert("ℹ️ Всі записи вже мають PAX_ID");
  }
}

/**
 * Заповнює SOURCE_SHEET та Напрям для всіх рядків
 */
function fillMissingMetadata() {
  var sheet = SpreadsheetApp.getActiveSheet();
  var sheetName = sheet.getName();
  var headers = getHeaders_(sheet);
  var lastRow = sheet.getLastRow();
  var startRow = SCRIPT_CONFIG.DATA_START_ROW;

  var dirCol = headers.indexOf("Напрям");
  var srcCol = headers.indexOf("SOURCE_SHEET");
  var direction = sheetName === SCRIPT_CONFIG.SHEET_UA_EU ? "УК → ЄВ" : "ЄВ → УК";
  var filled = 0;

  for (var row = startRow; row <= lastRow; row++) {
    var paxId = getPaxIdForRow_(sheet, row);
    if (!paxId) continue;

    var dirCell = sheet.getRange(row, dirCol + 1);
    var srcCell = sheet.getRange(row, srcCol + 1);

    if (!dirCell.getValue()) { dirCell.setValue(direction); filled++; }
    if (!srcCell.getValue()) { srcCell.setValue(sheetName); filled++; }
  }

  SpreadsheetApp.getUi().alert("✅ Заповнено " + filled + " порожніх полів метаданих");
}


