/**
 * Обробник форми — додає рядок в таблицю і синхронізує з CRM
 */
function addPassengerFromForm(data, sheetName) {
  try {
    var sheet = SpreadsheetApp.getActive().getSheetByName(sheetName);
    if (!sheet) return { success: false, error: "Аркуш не знайдено" };

    var headers = getHeaders_(sheet);
    var paxId = generatePaxId_();
    var now = new Date();
    var direction = sheetName === SCRIPT_CONFIG.SHEET_UA_EU ? "УК → ЄВ" : "ЄВ → УК";

    // Формуємо рядок
    var entry = {};
    for (var i = 0; i < SCRIPT_CONFIG.COLUMNS.length; i++) {
      entry[SCRIPT_CONFIG.COLUMNS[i]] = "";
    }

    entry["PAX_ID"] = paxId;
    entry["Напрям"] = direction;
    entry["SOURCE_SHEET"] = sheetName;
    entry["Дата створення"] = now;
    entry["Піб"] = data.name || "";
    entry["Телефон пасажира"] = data.phone || "";
    entry["Телефон реєстратора"] = data.phoneReg || "";
    entry["Кількість місць"] = data.seats || 1;
    entry["Адреса прибуття"] = data.address || "";
    entry["Дата виїзду"] = data.date || "";
    entry["Таймінг"] = data.timing || "";
    entry["Ціна квитка"] = data.price || "";
    entry["Завдаток"] = data.deposit || "";
    entry["Статус оплати"] = "Не оплачено";
    entry["Форма оплати"] = data.payForm || "";
    entry["Валюта"] = data.currency || "UAH";
    entry["Вага багажу"] = data.weight || "";
    entry["Статус ліда"] = "Новий";
    entry["Статус CRM"] = "Активний";

    // Записуємо в таблицю
    var values = objectToRow_(headers, entry);
    sheet.appendRow(values);

    // Розфарбовуємо останній рядок
    var lastRow = sheet.getLastRow();
    colorRowStatuses_(sheet, headers, lastRow);

    // Синхронізуємо з CRM API (створюємо пасажира)
    try {
      sendToCrmApi_("createPassenger", {
        sheet: sheetName,
        data: {
          smartId: "",
          name: data.name,
          phone: data.phone,
          phoneReg: data.phoneReg || "",
          seats: data.seats || 1,
          address: data.address,
          departureDate: data.date,
          timing: data.timing || "",
          vehicle: "",
          seat: "",
          price: data.price || "",
          deposit: data.deposit || "",
          payStatus: "Не оплачено",
          payForm: data.payForm || "",
          currency: data.currency || "UAH",
          weight: data.weight || "",
          weightPrice: "",
          createdBy: getUserEmail_()
        }
      });
    } catch (apiErr) {
      Logger.log("CRM sync on add failed: " + apiErr.message);
    }

    return { success: true, paxId: paxId };
  } catch (err) {
    return { success: false, error: err.message };
  }
}


